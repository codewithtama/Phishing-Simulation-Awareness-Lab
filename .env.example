# ============================================================
# Phishing Simulation Awareness Lab — Environment Variables
# Copy this file to .env and adjust values as needed.
# DO NOT commit the real .env file to version control.
# ============================================================

# ---- Gophish -----------------------------------------------
# Admin panel port (HTTPS)
GOPHISH_ADMIN_PORT=3333

# Landing page / phishing listener port (HTTP)
GOPHISH_PHISH_PORT=8080

# Initial admin password (change immediately after first login)
# Minimum 8 chars, at least 1 uppercase, 1 number, 1 symbol
GOPHISH_ADMIN_PASSWORD=PhishLab@2025!

# ---- MailHog -----------------------------------------------
# Web UI port
MAILHOG_UI_PORT=8025

# SMTP port (used by Gophish to send emails)
MAILHOG_SMTP_PORT=1025
